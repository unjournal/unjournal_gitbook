# Workshop Collab Tool - Environment Variables
# Copy to .env and fill in values

# Coda API (required for scaffold command)
# Get from: https://coda.io/account -> API settings
CODA_API_KEY=your_coda_api_key

# Netlify API (required for sync-forms command)
# Get from: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=your_netlify_token

# Google Docs (optional, V1 stretch)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json
